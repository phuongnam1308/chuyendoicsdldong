# Ví dụ dùng env JSON (ghi nguyên json trong một dòng hoặc escape nếu cần)
# SRC_JSON và DST_JSON chứa object kết nối (server,user,password,database) — table sẽ được chỉ định trong các file `config/targets/*.json`
# MAPPING_JSON chứa mảng mapping; MODULE_NAME chỉ định module tuỳ chỉnh trong src/modules/<module>.ts

SRC_JSON={"server":"TEN_SERVER_NGUON","user":"sa","password":"matkhau","database":"DB_NGUON"}
DST_JSON={"server":"TEN_SERVER_DICH","user":"sa","password":"matkhau","database":"DB_DICH"}
MAPPING_JSON=[{"nguon":"Id","dich":"id_bak","type":"int"},{"nguon":"Name","dich":"ten","type":"nvarchar"}]
MODULE_NAME=vi_du.chuyendoi

# Nếu muốn chuyển nhiều bảng, tạo các file JSON trong `config/targets/` mỗi file chứa object override cho từng bảng.
