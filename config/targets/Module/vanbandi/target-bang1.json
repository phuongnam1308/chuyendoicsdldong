{
  "nguon": { "table": "BangNguon" },
  "dich": { "table": "BangDich" },
  "mapping": [
    { "nguon": "Id", "dich": "id_bak", "type": "int" },
    { "nguon": "StatusText", "dich": "status", "type": "int", "rule": { "type": "map", "mapName": "statusMap", "default": 0 } },
    { "nguon": "Note", "dich": "ghi_chu", "type": "nvarchar", "rule": { "type": "trim" } }
  ],
  "options": {
    "batchSize": 500,
    "logDir": "logs"
  },
  "logFile": "logs/history_target-bang1.json"
}
